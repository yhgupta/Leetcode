class Solution {
    public boolean isBalanced(TreeNode root) {
        if( root == null){
            return true;
        }
        findHeight(root);
        return  ans;
    }

    boolean ans = true;

    private int findHeight(TreeNode root){
        if ( root == null ){
            return 0;
        }

        int left = findHeight(root.left);
        int right = findHeight(root.right);

        ans = ans && (Math.abs(left - right) <= 1);
        return 1 + Math.max(left, right);
    }

}
