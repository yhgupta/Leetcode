class Solution {
    public boolean searchMatrix(int[][] M, int T) {
        int n = M.length, m = M[0].length;
        int start = M[0][m-1] , i = 0, j = m-1;
    
        while( i >= 0 && j >= 0 && i < n && j < m ){
            if ( M[i][j] == T ){
                return true;
            }
            else if( M[i][j] > T ){
                j--;
            } else {
                i++;
            }
        }
        return false;
    }
}
