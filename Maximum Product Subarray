class Solution {
    public int maxProduct(int[] N) {
        int max = N[0], min = N[0], ans = N[0], n = N.length;
        for( int i = 1 ; i < n ; i++ ){
            if( N[i] < 0 ){
                int temp = min;
                min = max;
                max = temp;
            }

            max = Math.max(max*N[i], N[i]);
            min = Math.min(min*N[i], N[i]);

            ans = Math.max(ans, Math.max(max,min));
        }
        return ans;
    }
}
