class Solution {
    public int majorityElement(int[] N) {
        int count = 0, num = N[0];
        for( int i = 0 ; i < N.length ; i++ ){
            if( count == 0 ){
                num = N[i];
            } 
            
            if( num == N[i] ){
                count++;
            } else {
                count--;
            }
        }
        return num;
    }
}
