class Solution {
    public void rotate(int[][] M) {
        int n = M.length;
        for (int i = 0; i <= n / 2; i++) {
            for (int j = i; j < n - 1 - i; j++) {
                int temp = M[i][j];
                M[i][j] = M[n - 1 - j][i];
                M[n - 1 - j][i] = M[n - 1 - i][n - 1 - j];
                M[n - 1 - i][n - 1 - j] = M[j][n - 1 - i];
                M[j][n - 1 - i] = temp;
            }
        }
    }
}
