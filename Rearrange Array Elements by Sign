class Solution {
    public int[] rearrangeArray(int[] N) {
        int size = N.length;
        int[] A = new int[size];
        int n = 1 , p = 0;
        for( int i = 0 ; i < size ; i++ ){
            if( N[i] < 0 ){
                A[n] = N[i];
                n += 2;
            } else {
                A[p] = N[i];
                p += 2;
            }
        }
        return A;
    }
}
