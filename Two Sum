class Solution {
    public int[] twoSum(int[] N, int T) {
        int[] ans = new int[2];
        Map<Integer, Integer> map = Collections.synchronizedMap(new HashMap<>());
        for( int i = 0 ; i < N.length ; i++ ){
            int val = T-N[i];
            if( !map.containsKey(val) ){
                map.put(N[i], i);
            } else {
                ans[0] = map.get(val);
                ans[1] = i;
                return ans;
            }
        }
        return ans;
    }
}
