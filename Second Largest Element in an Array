import java.util.Arrays;

class Solution {
    
    public int getSecondLargest(int[] N) {
      int max1 = Integer.MIN_VALUE, max2 = Integer.MIN_VALUE;
        for( int i = 0 ; i <  N.length ; i++ ){
            if( max1 < N[i] ){
                max1 = N[i];
            }

            if( N[i] != max1 && max2 < N[i] ){
                max2 = N[i];
            }
        }

        return max2 == Integer.MIN_VALUE ? -1 : max2;
    }
}
